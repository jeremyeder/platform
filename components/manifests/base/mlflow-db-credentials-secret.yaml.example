# MLflow database credentials
# Copy this file to mlflow-db-credentials-secret.yaml and customize values
#
# This secret must be created in the redhat-ods-applications namespace
# (where the MLflow Operator deploys MLflow).
#
# To apply: kubectl apply -f mlflow-db-credentials-secret.yaml -n redhat-ods-applications
#
apiVersion: v1
kind: Secret
metadata:
  name: mlflow-db-credentials
  namespace: redhat-ods-applications
  labels:
    app: mlflow
    app.kubernetes.io/name: mlflow
type: Opaque
stringData:
  # Format: postgresql://<user>:<password>@<host>:<port>/<database>?sslmode=<mode>
  # Use sslmode=disable for non-SSL PostgreSQL, or sslmode=require for production with SSL
  uri: "postgresql://postgres:CHANGE_ME_IN_PRODUCTION@postgresql.ambient-code.svc.cluster.local:5432/mlflow?sslmode=disable"
