# Dev Bootstrap Configuration
# Copy to .dev-bootstrap.env and fill in your values:
#   cp .dev-bootstrap.env.example .dev-bootstrap.env
#
# Values support ${ENV_VAR} indirection so you can reference
# existing shell environment variables instead of pasting secrets.
#
# Uncommented lines are required. Commented lines are optional —
# uncomment to enable that integration.

# --- Workspace ---
BOOTSTRAP_WORKSPACE_NAME=my-dev
BOOTSTRAP_WORKSPACE_DISPLAY_NAME="My Dev Workspace"

# --- Anthropic API Key ---
BOOTSTRAP_ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY}

# --- GitHub PAT (ghp_, github_pat_, etc.) ---
# BOOTSTRAP_GITHUB_PAT=${GITHUB_TOKEN}

# --- Jira (all three required to connect) ---
# BOOTSTRAP_JIRA_URL=https://issues.redhat.com
# BOOTSTRAP_JIRA_EMAIL=you@redhat.com
# BOOTSTRAP_JIRA_API_TOKEN=${JIRA_API_TOKEN}

# --- GitLab ---
# BOOTSTRAP_GITLAB_PAT=${GITLAB_TOKEN}
# BOOTSTRAP_GITLAB_INSTANCE_URL=https://gitlab.com
